# Kite Agent Commerce Environment Variables
# Copy this to `.env` and fill in your values (testnet only!)

# ─────────────────────────────────────────────────────────────────────────
# KITE AI TESTNET (Chain ID 2368)
# ─────────────────────────────────────────────────────────────────────────

# RPC Endpoint (Kite Testnet)
KITE_RPC_URL=https://rpc-testnet.gokite.ai/

# Private key for deployment (testnet faucet: https://faucet.gokite.ai/)
# ⚠️ NEVER use mainnet private keys here!
DEPLOYER_PRIVATE_KEY=your_testnet_private_key_here

# ─────────────────────────────────────────────────────────────────────────
# CONTRACT ADDRESSES (Kite Testnet - Update Before Deploy)
# ─────────────────────────────────────────────────────────────────────────

# USDC on Kite Testnet (Bridged USDC.e)
USDC_ADDRESS=0x6fB3e8F910d7835515f53B25c4C4DE7741038C58

# AI Validator Contract (EVM-compatible validator node)
AI_VALIDATOR_ADDRESS=0x1234567890123456789012345678901234567890

# $TECH Token Address on Kite Testnet
TECH_TOKEN_ADDRESS=0xABCDEF0123456789abcdef0123456789ABCDEF01

# Treasury Address (for $TECH burn/recycle split)
TREASURY_ADDRESS=0x789ABCDEF0123456789abcdef0123456789ABCDEF0

# ─────────────────────────────────────────────────────────────────────────
# DEPLOYMENT CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────

# Burn Ratio (1000-9000) — 5000 = 50% burn, 50% recycle
INITIAL_BURN_RATIO=5000

# Discount (0-5000) — 2500 = 25% cheaper than USDC
INITIAL_DISCOUNT=2500

# ─────────────────────────────────────────────────────────────────────────
# VERIFICATION (Block Explorer)
# ─────────────────────────────────────────────────────────────────────────

# Kite Testnet Block Explorer API Key (from https://scan-testnet.gokite.ai/)
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# ─────────────────────────────────────────────────────────────────────────
# HERMES AGENT (Local Dev)
# ─────────────────────────────────────────────────────────────────────────

HERMES_GATEWAY_URL=http://127.0.0.1:8642
HERMES_API_KEY=your_hermes_api_key_here

# ─────────────────────────────────────────────────────────────────────────
# DEVELOPMENT (Anvil / Local testing)
# ─────────────────────────────────────────────────────────────────────────

ANVIL_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ─────────────────────────────────────────────────────────────────────────
# OUTPUTS
# ─────────────────────────────────────────────────────────────────────────

# Deployed contract addresses (auto-generated after broadcast)
DEPLOYED_AGENT_ESCROW=
DEPLOYED_TECH_ROUTER=
